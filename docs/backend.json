
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a registered user of the FlowPro application.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "approved", "blocked"] },
        "isOnboarded": { "type": "boolean" },
        "plan": { "type": "string", "enum": ["nenhum", "mensal", "vitalicio"], "default": "nenhum" },
        "totalEarnings": { "type": "number", "default": 0 },
        "dailyActions": { "type": "number", "default": 0 },
        "totalActions": { "type": "number", "default": 0 },
        "lastActionAt": { "type": "string", "format": "date-time" },
        "dailyUsage": {
          "type": "object",
          "properties": {
            "leadsUsed": { "type": "number", "default": 0 },
            "messagesUsed": { "type": "number", "default": 0 }
          }
        }
      },
      "required": ["id", "email", "name", "createdAt", "status"]
    },
    "Subscription": {
      "title": "Subscription",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "planType": { "type": "string", "enum": ["monthly", "lifetime", "lifetime_admin"] },
        "status": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" }
      }
    },
    "Earning": {
      "title": "Earning",
      "type": "object",
      "properties": {
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" },
        "description": { "type": "string" }
      },
      "required": ["amount", "date"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/User" },
      "description": "Stores user profile data."
    },
    "/users/{userId}/subscriptions/{subId}": {
      "schema": { "$ref": "#/backend/entities/Subscription" },
      "description": "User subscription data."
    },
    "/users/{userId}/earnings/{earningId}": {
      "schema": { "$ref": "#/backend/entities/Earning" },
      "description": "Individual earning records for chart and tracking."
    }
  }
}
