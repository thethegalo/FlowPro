
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a registered user of the FlowPro application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "email": {
          "type": "string",
          "description": "The user's email address.",
          "format": "email"
        },
        "name": {
          "type": "string",
          "description": "The user's full name."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp when the user account was created.",
          "format": "date-time"
        },
        "status": {
          "type": "string",
          "description": "Current status of the user.",
          "enum": ["pending", "approved", "blocked"]
        },
        "isOnboarded": {
          "type": "boolean",
          "description": "Indicates if the user has completed the initial onboarding quiz."
        }
      },
      "required": [
        "id",
        "email",
        "name",
        "createdAt",
        "status"
      ]
    },
    "Subscription": {
      "title": "Subscription",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "planType": { "type": "string", "enum": ["monthly", "lifetime", "lifetime_admin"] },
        "status": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/User" },
      "description": "Stores user profile data."
    },
    "/users/{userId}/subscriptions/{subId}": {
      "schema": { "$ref": "#/backend/entities/Subscription" },
      "description": "User subscription data."
    }
  }
}
