{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a registered user of the FlowPro application.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "approved", "blocked"] },
        "isOnboarded": { "type": "boolean" },
        "plan": { "type": "string", "enum": ["nenhum", "mensal", "trimestral", "vitalicio"], "default": "nenhum" },
        "totalEarnings": { "type": "number", "default": 0 },
        "dailyActions": { "type": "number", "default": 0 },
        "totalActions": { "type": "number", "default": 0 },
        "lastActionAt": { "type": "string", "format": "date-time" },
        "dailyUsage": {
          "type": "object",
          "properties": {
            "leadsUsed": { "type": "number", "default": 0 },
            "messagesUsed": { "type": "number", "default": 0 }
          }
        }
      },
      "required": ["id", "email", "name", "createdAt", "status"]
    },
    "CapturedLead": {
      "title": "CapturedLead",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "businessType": { "type": "string" },
        "capturedAt": { "type": "string", "format": "date-time" },
        "source": { "type": "string" },
        "rating": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "address": { "type": "string" },
        "status": { "type": "string" },
        "website": { "type": "string" }
      }
    },
    "MissionProgress": {
      "title": "MissionProgress",
      "type": "object",
      "properties": {
        "missionId": { "type": "string" },
        "isCompleted": { "type": "boolean" },
        "completedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/User" },
      "description": "Stores user profile data."
    },
    "/users/{userId}/capturedLeads/{leadId}": {
      "schema": { "$ref": "#/backend/entities/CapturedLead" },
      "description": "Leads saved by the user."
    },
    "/users/{userId}/missionProgress/{missionId}": {
      "schema": { "$ref": "#/backend/entities/MissionProgress" },
      "description": "Track completion of journey missions."
    }
  }
}
