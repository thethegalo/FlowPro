rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return request.auth.token.email == 'thethegalo@gmail.com'; }
    function isOwner(userId) { return request.auth.uid == userId; }

    match /users/{userId} {
      allow read, create: if isSignedIn();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      // Permissão recursiva total para todas as subcoleções (leads, progress, earnings, etc)
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }
    
    match /missions/{missionId} { 
      allow read: if isSignedIn();
      match /steps/{stepId} { allow read: if isSignedIn(); }
    }
    
    match /scripts/{scriptId} { allow read: if isSignedIn(); }
  }
}