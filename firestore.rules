/**
 * FlowPro Security Rules
 * 
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model where all personal data (quiz responses, 
 * plans, subscriptions, progress, and chat history) is private to the authenticated user. 
 * Global educational content (missions and scripts) is accessible to all registered users 
 * to facilitate the "step-by-step" learning journey.
 * 
 * Data Structure:
 * - /users/{userId}: The root user profile.
 * - /users/{userId}/...: Private subcollections for user-specific state.
 * - /missions: Global library of daily tasks and instructions.
 * - /scripts: Global library of sales templates.
 * 
 * Key Security Decisions:
 * 1. Ownership Isolation: Users can only read or write data within their own /users/{userId} tree.
 * 2. Relational Integrity: On creation of user-specific documents, the rules enforce that 
 *    the internal 'userId' field matches the path parameter and the authenticated user's UID.
 * 3. Prototyping Flexibility: Data types and non-essential fields are not validated to allow 
 *    rapid frontend iteration, but ownership is strictly enforced.
 * 4. Read-Only Global Content: Missions and scripts are publicly readable by any signed-in 
 *    user but cannot be modified via the client-side SDK.
 * 
 * Denormalization for Authorization:
 * Documents in user subcollections include a 'userId' field. This allows rules to verify 
 * ownership directly on the resource without traversing the parent tree, ensuring high 
 * performance and predictable query authorization.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the provided userId matches the authenticated user's UID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Verifies ownership and ensures the document exists for updates/deletes. */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /** @description Validates relational integrity: internal userId must match the path and auth. */
    function isValidUserResource(userId) {
      return request.resource.data.userId == userId && request.resource.data.userId == request.auth.uid;
    }

    /** @description Ensures critical ownership fields cannot be changed during an update. */
    function isUnchanged(field) {
      return !(field in request.resource.data) || request.resource.data[field] == resource.data[field];
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the root User document.
     * @path /users/{userId}
     * @allow get, list, create, update: if isOwner(userId)
     * @deny delete: if true (Users cannot delete their own profile in this version)
     * @principle Self-creation and ownership-based access.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if false;

      /**
       * @description User's quiz answers for personalization.
       * @path /users/{userId}/quizResponses/{quizResponseId}
       * @allow create: if isOwner(userId) && isValidUserResource(userId)
       * @deny update: if false (Quiz responses are typically immutable once submitted)
       */
      match /quizResponses/{quizResponseId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidUserResource(userId);
        allow update, delete: if false;
      }

      /**
       * @description AI-generated sales plans tailored to the user.
       * @path /users/{userId}/personalizedPlans/{planId}
       * @allow get, list: if isOwner(userId)
       */
      match /personalizedPlans/{planId} {
        allow get, list: if isOwner(userId);
        allow create, update, delete: if false; // Plans are generated by backend/AI
      }

      /**
       * @description User subscription status and payment plan details.
       * @path /users/{userId}/subscriptions/{subscriptionId}
       * @allow get, list: if isOwner(userId)
       */
      match /subscriptions/{subscriptionId} {
        allow get, list: if isOwner(userId);
        allow create, update, delete: if false; // Managed by payment webhooks/backend
      }

      /**
       * @description Tracking progress through daily missions and simulated earnings.
       * @path /users/{userId}/missionProgress/{progressId}
       * @allow create, update: if isOwner(userId) && isValidUserResource(userId)
       */
      match /missionProgress/{progressId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidUserResource(userId);
        allow update: if isExistingOwner(userId) && isUnchanged('userId');
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Chat sessions with the AI Mentor.
       * @path /users/{userId}/chatSessions/{sessionId}
       */
      match /chatSessions/{sessionId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidUserResource(userId);
        allow update: if isExistingOwner(userId) && isUnchanged('userId');
        allow delete: if isExistingOwner(userId);

        /**
         * @description Individual messages within a chat session.
         * @path /users/{userId}/chatSessions/{sessionId}/messages/{messageId}
         */
        match /messages/{messageId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && isValidUserResource(userId);
          allow update, delete: if false; // Messages are usually immutable
        }
      }
    }

    /**
     * @description Global library of Missions and steps.
     * @path /missions/{missionId}
     * @allow get, list: if isSignedIn()
     * @deny create, update, delete: if true (Managed by admins)
     * @principle Read-only access for authenticated learners.
     */
    match /missions/{missionId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;

      match /steps/{stepId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if false;
      }
    }

    /**
     * @description Global library of sales and closing scripts.
     * @path /scripts/{scriptId}
     * @allow get, list: if isSignedIn()
     * @deny create, update, delete: if true
     */
    match /scripts/{scriptId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }
  }
}