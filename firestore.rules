
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return request.auth.token.email == 'thethegalo@gmail.com'; }
    function isOwner(userId) { return request.auth.uid == userId; }

    match /users/{userId} {
      allow read, create: if isSignedIn();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      match /capturedLeads/{leadId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      
      match /missionProgress/{missionId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      
      match /earnings/{earningId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      
      match /subscriptions/{subId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isAdmin();
      }

      // Garante acesso total a todas as subcoleções para o dono ou admin de forma recursiva
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }
    
    match /missions/{missionId} { 
      allow read: if isSignedIn();
      match /steps/{stepId} { allow read: if isSignedIn(); }
    }
    
    match /scripts/{scriptId} { allow read: if isSignedIn(); }
  }
}
