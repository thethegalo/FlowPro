
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return request.auth.token.email == 'thethegalo@gmail.com'; }
    function isOwner(userId) { return request.auth.uid == userId; }

    match /users/{userId} {
      // Only owner or admin can read/update a profile
      // Anyone signed in can create their own initial profile
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isSignedIn();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      // Recursive permissions for subcollections (leads, progress, earnings, etc)
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }
    
    // Explicit permission for admin to list the users collection
    match /users {
      allow list: if isAdmin();
    }
    
    match /missions/{missionId} { 
      allow read: if isSignedIn();
      match /steps/{stepId} { allow read: if isSignedIn(); }
    }
    
    match /scripts/{scriptId} { allow read: if isSignedIn(); }
  }
}
